# ─────────────────────────────────────────────────────────────────────────────
# Steward Table — Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local for local development.
# See README or docs/ENVIRONMENT_VARIABLES.md for detailed setup instructions.

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string. Required for all environments.
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/steward_table"

# ── Authentication (NextAuth v5) ───────────────────────────────────────────
# Secret key used to encrypt sessions and tokens. Required.
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"

# Application URL. Used for OAuth callbacks and session handling.
# Required in production. Optional in development (defaults to http://localhost:3000).
NEXTAUTH_URL="http://localhost:3000"

# ── OAuth Providers ────────────────────────────────────────────────────────
# Google OAuth credentials for sign-in. Optional but recommended for production.
# Create application: https://console.cloud.google.com/apis/credentials
# Set redirect URI to: [NEXTAUTH_URL]/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Email Provider (Resend) ────────────────────────────────────────────────
# API key for Resend email service. Required for passwordless sign-in and notifications.
# Get key at: https://resend.com/api-keys
RESEND_API_KEY=""

# Email address to send notifications from.
# Optional. Defaults to "noreply@stewardtable.com" for team invites,
# "orders@table.steward.app" for order notifications.
# Must be a verified sender in Resend.
RESEND_FROM_EMAIL="noreply@stewardtable.com"

# ── Encryption ─────────────────────────────────────────────────────────────
# AES-256-GCM encryption key for sensitive data at rest.
# Must be exactly 64 hex characters (32 bytes).
# Generate with: openssl rand -hex 32
# Required for production. Optional for development.
ENCRYPTION_KEY=""

# ── Cloud Storage (R2 / MinIO / S3) ────────────────────────────────────────
# S3-compatible storage endpoint. For Cloudflare R2 or MinIO.
# Optional. If not set, storage features are disabled.
# Examples:
#   - Cloudflare R2: https://[account-id].r2.cloudflarestorage.com
#   - MinIO local: http://minio:9000
R2_ENDPOINT=""

# S3-compatible storage access key.
R2_ACCESS_KEY_ID=""

# S3-compatible storage secret key.
R2_SECRET_ACCESS_KEY=""

# S3-compatible storage bucket name for uploads.
# Optional. Defaults to "steward-table".
R2_BUCKET_NAME="steward-table"

# ── App Configuration ──────────────────────────────────────────────────────
# Public-facing app URL. Used in client-side redirects and email links.
# Must match NEXTAUTH_URL for same-origin requests.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Twilio (optional — SMS notifications) ─────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+1...

# ── Development / Debugging ────────────────────────────────────────────────
# Environment type. Set by build system. Do not set manually unless testing.
# Values: development, production, test
# NODE_ENV="development"
